# Copy to .env.local for local-only settings.
# Do not commit .env.local.

# Main account: prefer the persistent browser profile over storing credentials.
MELVOR_MAIN_EMAIL=
MELVOR_MAIN_PASSWORD=
MELVOR_PROFILE=
MELVOR_PORT=9223

# Test account: use this for CI/local login experiments.
MELVOR_TEST_EMAIL=
MELVOR_TEST_PASSWORD=
MELVOR_TEST_PROFILE=/absolute/path/to/mpt-melvor-test-profile
MELVOR_TEST_PORT=9224
